{
  "name": "poketcg-ex-sim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "sim": "esbuild scripts/simulate.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/sim.cjs && node node_modules/.cache/sim.cjs",
    "test:rules": "esbuild scripts/rules-regression.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/rules-regression.cjs && node node_modules/.cache/rules-regression.cjs",
    "test:ai": "esbuild scripts/ai-regression.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/ai-regression.cjs && node node_modules/.cache/ai-regression.cjs",
    "benchmark:ai": "esbuild scripts/benchmark-ai.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/benchmark-ai.cjs && node node_modules/.cache/benchmark-ai.cjs",
    "benchmark:ai:release": "npm run benchmark:ai -- 20 512 7 mirror --output=benchmark-results/ai-latest.json",
    "test:cards": "esbuild tests/index.ts --bundle --platform=node --format=cjs --outfile=node_modules/.cache/card-tests.cjs && node node_modules/.cache/card-tests.cjs"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
